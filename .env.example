# Copy this file to .env and adjust values for your setup

# InfluxDB bootstrap
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminadminadmin
INFLUXDB_ORG=rasp-monitor
INFLUXDB_BUCKET=machine-data
INFLUXDB_TOKEN=replace-with-a-long-random-token

# Grafana admin login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# OPC UA connection
OPCUA_ENDPOINT=opc.tcp://10.195.222.80:4840
# Allowed values: None, Sign, SignAndEncrypt
OPCUA_SECURITY_MODE=None
# Allowed values: None, Basic256Sha256 (extend in code if needed)
OPCUA_SECURITY_POLICY=None
OPCUA_USERNAME=
OPCUA_PASSWORD=

# Comma-separated list of NodeIds to poll
# Example with namespace index 2 and string identifiers:
OPCUA_NODE_IDS=ns=3;s="OPCUA_Dataset"."Prozessdaten"."ST10_Wanne_09"."Leitwert"."ISTwert",ns=3;s="OPCUA_Dataset"."Prozessdaten"."ST10_Wanne_09"."Temperatur_IST",ns=3;s="OPCUA_Dataset"."Prozessdaten"."ST13_Wanne_12"."Leitwert"."ISTwert",ns=3;s="OPCUA_Dataset"."Prozessdaten"."ST13_Wanne_12"."Temperatur_IST",ns=3;s="OPCUA_Dataset"."E_10_Jena"."e10Status"

# Polling interval in milliseconds
OPCUA_POLL_INTERVAL_MS=1000

# Optional metadata tag
INFLUX_MEASUREMENT=opcua_metrics
INFLUX_TAG_MACHINE=machine_1
